# ─── Demo 部署用環境變數 ─────────────────────────────────────────────────
# 用法：cp .env.demo.example .env.demo  然後填好下面的值
# 啟動：docker compose --env-file .env.demo -f docker-compose.demo.yml up -d --build

# ── 對外 port（建議 demo 直接用 80；如果機器上 80 已被 nginx 用就改 8080） ──
APP_PORT=8080

# ── MySQL（容器內部，不對外暴露 port，所以密碼隨意但別太弱） ──
MYSQL_ROOT_PASSWORD=demo_root_pw_change_me
MYSQL_DATABASE=i18n_manager
MYSQL_USER=i18n
MYSQL_PASSWORD=demo_app_pw_change_me

# ── App ──
# 隨機長字串，務必換掉。換了會讓所有人重新登入
JWT_SECRET=please_replace_with_a_long_random_string

# 第一個系統 owner 的 openId（隨意填，bootstrap 完就用不到）
OWNER_OPEN_ID=demo_owner
OWNER_NAME=Demo Admin

# Bootstrap 帳密：第一次進系統用這組登入建 admin user，之後可以清空
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=admin123

# 登入頁標題
VITE_APP_TITLE=多語系翻譯管理系統 (Demo)
