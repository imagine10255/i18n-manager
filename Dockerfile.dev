# 開發環境 Dockerfile — 提供給 docker compose --profile dev 使用
FROM node:22-alpine

WORKDIR /app

RUN npm install -g pnpm

# package 文件先 copy 進去做 install，剩下的 source 由 docker-compose 的 bind mount 掛上來
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

# Express + Vite middleware 共用一個 port；pnpm dev 已固定 PORT=3001
EXPOSE 3001

CMD ["pnpm", "dev"]
