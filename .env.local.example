# ─── 必填 ─────────────────────────────────────────────────────────────────────

# MySQL 連線
DATABASE_URL=mysql://root:root@localhost:3306/i18n_manager

# JWT 簽章金鑰（隨機長字串即可；換金鑰會讓所有現有 cookie 失效）
JWT_SECRET=isuxnDSSPXMco7UrpAE7kC

# 第一個系統擁有者的 openId — 沒建任何 DB 使用者前，本地 fallback 登入用這個 openId 寫入
OWNER_OPEN_ID=Piw5qJW5NHTbQz2nqzJg36

# ─── 選用 ─────────────────────────────────────────────────────────────────────

# 擁有者顯示名稱 fallback
OWNER_NAME=ADMIN

# Bootstrap 登入：DB 還沒人時，用這組帳密進系統（建好 admin user 後可移除）
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=admin123

# Login 頁顯示的標題（不設預設「多語系翻譯管理系統」）
VITE_APP_TITLE=多語系翻譯管理系統
